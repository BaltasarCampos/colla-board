{
  "name": "colla-board",
  "version": "1.0.0",
  "description": "collaborative whiteboard app",
  "main": "index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest server",
    "test:watch": "jest --watch server",
    "test:coverage": "jest --coverage server",
    "test:unit": "jest server/__tests__/unit",
    "test:integration": "jest server/__tests__/integration",
    "test:client": "cd client && npm test -- --no-coverage --watchAll=false",
    "test:client:watch": "cd client && npm test",
    "test:all": "npm run test && npm run test:client"
  },
  "keywords": [],
  "author": "Baltasar Campos Ballesteros",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
